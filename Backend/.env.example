# Copy this file, rename to .env, and fill in the values
# On Render: add these as Environment Variables in the dashboard

PORT=5001
NODE_ENV=production

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?appName=Cluster0

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_key_here

# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
